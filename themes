    height: 20px;
    stroke: var(--ink);
    stroke-width: 2;
  }
  .topbar {
    padding: 12px;
  }
  .topbar h1 {
    font-size: 18px;
  }
  .view-tabs {
    flex-direction: column;
    align-items: stretch;
    gap: 12px;
    padding: 0 12px;
  }
  .view-tabs-left,
  .view-tabs-right {
    justify-content: flex-start;
    flex-wrap: wrap;
  }
  .view-tab {
    flex: 1;
    justify-content: center;
    min-width: 80px;
  }
  .filter-btn {
    flex: 1;
    justify-content: center;
    min-width: 80px;
  }
  .board-cols {
    grid-template-columns: 1fr;
    padding: 12px;
  }
  .board-cols.show-review {
    grid-template-columns: 1fr;
  }
  .dash-grid,
  .reflect-grid,
  .team-grid {
    grid-template-columns: 1fr;
