}
.habit-water-cell-wave {
  position: absolute;
  top: -7px;
  left: -50%;
  width: 200%;
  height: 14px;
  border-radius: 50%;
  background: var(--primary);
  opacity: 0.55;
  animation: habitWaterDrift 4s linear infinite;
}

.habit-water-cell-wave--back {
