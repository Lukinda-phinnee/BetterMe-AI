  color: var(--ink);
  position: relative;
  font-family: var(--font-body, inherit);
  overflow: hidden;
}

.goal-history-sidebar {
  display: flex;
  flex-direction: column;
  background-color: var(--surface);
  border-right: 1px solid var(--border);
