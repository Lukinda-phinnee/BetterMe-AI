}

.habit-water-cell-body {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: 9px;
  background: var(--surface-2);
  border: 1px solid var(--border);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

