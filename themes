  border: 2px solid var(--primary);
  box-shadow: 0 0 0 3px var(--primary-tint);
}

.habit-water-cell--rest .habit-water-cell-body {
  background: repeating-linear-gradient(135deg, var(--surface-2) 0 6px, transparent 6px 12px);
  opacity: 0.7;
}

.habit-water-cell--future .habit-water-cell-body {
  opacity: 0.45;
}

.habit-water-cell:hover .habit-water-cell-body {
  transform: translateY(-2px);
  box-shadow: 0 6px 14px -4px rgba(0, 0, 0, 0.15);
}

.habit-water-cell-fill {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, var(--primary) 0%, var(--primary-dark) 100%);
  animation: habitWaterRise 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
  z-index: 1;
}

@keyframes habitWaterRise {
  from {
    height: 0% !important;
