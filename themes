  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.mng-detail-row-icon svg {
  width: 13px;
  height: 13px;
  stroke: var(--ink-soft);
}

.mng-detail-row-label {
  font-size: 13px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  color: var(--muted);
  margin-bottom: 2px;
}

.mng-detail-row-value {
  font-size: 14px;
  color: var(--ink);
  line-height: 1.4;
}

.mng-meta-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  margin-top: 16px;
  padding-top: 16px;
  border-top: 1px dashed var(--border);
}

.mng-chip {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 13px;
  font-weight: 500;
  color: var(--ink-soft);
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 4px 9px;
  border-radius: 999px;
}
.mng-chip svg {
  stroke: var(--muted);
}

.mng-cal-section {
  margin-bottom: 16px;
}

.mng-cal-title {
  font-size: 13px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--muted);
  margin-bottom: 10px;
}

.mng-cal-legend {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-top: 8px;
}

.mng-legend-item {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 13px;
  color: var(--muted);
}

.mng-legend-dot {
  width: 10px;
  height: 10px;
  border-radius: 3px;
  display: inline-block;
}
.mng-legend-dot--done {
  background: linear-gradient(180deg, var(--primary) 0%, var(--primary-dark) 100%);
}
.mng-legend-dot--partial {
  background: linear-gradient(180deg, var(--primary) 0%, var(--primary-dark) 100%);
  opacity: 0.5;
}
.mng-legend-dot--empty {
  background: var(--border);
}

.mng-insight-card {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  background: var(--primary-tint);
  border: 1px solid rgba(217, 119, 6, 0.18);
  border-radius: 12px;
  padding: 14px 16px;
  margin-bottom: 4px;
}

.mng-insight-icon {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  background: rgba(217, 119, 6, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.mng-insight-icon svg {
  width: 16px;
  height: 16px;
  stroke: var(--primary);
}

.mng-insight-text {
  font-size: 14px;
  line-height: 1.55;
  color: var(--ink);
  margin: 0;
  padding-top: 6px;
}

.mng-edit-section {
  margin-bottom: 16px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--border);
}
.mng-edit-section:last-of-type {
  border-bottom: none;
}

.mng-edit-section-title {
  font-size: 13px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--muted);
  margin-bottom: 16px;
}

.mng-intention-preview {
  display: flex;
  align-items: baseline;
  gap: 16px;
  background: var(--surface-2);
  border: 1px dashed var(--border);
  border-radius: 10px;
  padding: 10px 14px;
  font-size: 14px;
  color: var(--ink);
  line-height: 1.5;
  margin-top: -4px;
}

.mng-intention-preview-label {
  font-size: 13px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--muted);
  flex-shrink: 0;
}

.mng-danger-zone {
  margin-top: 8px;
  border: 1px solid rgba(220, 38, 38, 0.18);
  border-radius: 12px;
  padding: 16px;
  background: rgba(220, 38, 38, 0.03);
}

.mng-danger-zone-title {
  font-size: 13px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #ef4444;
  margin-bottom: 16px;
}

.mng-danger-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 16px 0;
}
.mng-danger-row + .mng-danger-row {
  border-top: 1px solid rgba(220, 38, 38, 0.1);
  margin-top: 16px;
  padding-top: 16px;
}

.mng-danger-name {
  font-size: 14px;
  font-weight: 600;
  color: var(--ink);
}

.mng-danger-sub {
  font-size: 13px;
  color: var(--muted);
  margin-top: 2px;
}

.mng-btn {
  flex-shrink: 0;
  border: none;
  border-radius: 8px;
  padding: 8px 16px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: opacity 0.15s ease, background 0.15s ease;
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
}
.mng-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}
.mng-btn--outline-warn {
  background: transparent;
  border: 1.5px solid rgba(220, 38, 38, 0.35);
  color: #ef4444;
}
.mng-btn--outline-warn:hover:not(:disabled) {
  background: rgba(220, 38, 38, 0.07);
}
.mng-btn--danger {
  background: #ef4444;
  color: #fff;
}
.mng-btn--danger:hover:not(:disabled) {
  background: #dc2626;
}

[data-theme=dark] .mng-header {
  border-color: rgba(255, 255, 255, 0.08);
}
[data-theme=dark] .mng-stat-strip {
  background: rgba(255, 255, 255, 0.04);
}
[data-theme=dark] .mng-stat-divider {
  background: rgba(255, 255, 255, 0.08);
}
[data-theme=dark] .mng-intention-card {
  background: rgba(255, 255, 255, 0.04);
  border-color: rgba(255, 255, 255, 0.08);
}
[data-theme=dark] .mng-fill--cue {
  background: rgba(16, 185, 129, 0.15);
  color: #34d399;
}
[data-theme=dark] .mng-fill--action {
  background: rgba(251, 191, 36, 0.15);
  color: #fbbf24;
}
[data-theme=dark] .mng-chip {
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.1);
}
[data-theme=dark] .mng-detail-row-icon {
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.1);
}
[data-theme=dark] .mng-insight-card {
  background: rgba(217, 119, 6, 0.1);
  border-color: rgba(217, 119, 6, 0.22);
}
[data-theme=dark] .mng-danger-zone {
  background: rgba(220, 38, 38, 0.05);
  border-color: rgba(220, 38, 38, 0.22);
}
[data-theme=dark] .mng-intention-preview {
  background: rgba(255, 255, 255, 0.04);
  border-color: rgba(255, 255, 255, 0.12);
}
[data-theme=dark] .mng-habit-row--active {
  background: rgba(217, 119, 6, 0.12) !important;
}
[data-theme=dark] .mng-legend-dot--empty {
  background: rgba(255, 255, 255, 0.12);
}

@keyframes wr-fade-in {
  from {
    opacity: 0;
    transform: translateY(8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
@keyframes wr-spin {
  to {
    transform: rotate(360deg);
  }
}
@keyframes wr-pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.4;
  }
}
@keyframes wr-shimmer {
  0% {
    background-position: -400px 0;
  }
  100% {
    background-position: 400px 0;
  }
}
@keyframes wr-scale-in {
  from {
    opacity: 0;
    transform: scale(0.94);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}
.wr-page {
  min-height: 100vh;
  background: var(--bg);
  padding: 20px 16px;
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
  color: var(--ink);
  -webkit-font-smoothing: antialiased;
}
@media (min-width: 768px) {
  .wr-page {
    padding: 12px;
  }
}

.wr-container {
  width: 100%;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.wr-stepper {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 20px;
  box-shadow: var(--shadow);
  transition: background 200ms cubic-bezier(0.4, 0, 0.2, 1), border-color 200ms cubic-bezier(0.4, 0, 0.2, 1);
}
@media (min-width: 768px) {
  .wr-stepper {
    padding: 24px;
  }
}
.wr-stepper__top {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-bottom: 20px;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--border);
}
@media (min-width: 640px) {
  .wr-stepper__top {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
  }
}
.wr-stepper__meta {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 6px;
  flex-wrap: wrap;
}
.wr-stepper__badge {
  display: inline-flex;
  align-items: center;
  padding: 3px 10px;
  border-radius: 999px;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  background: var(--primary-tint);
  color: var(--primary);
  border: 1px solid transparent;
  transition: background 200ms cubic-bezier(0.4, 0, 0.2, 1);
}
.wr-stepper__time-hint {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 12px;
  color: var(--muted);
}
.wr-stepper__time-hint svg {
  width: 14px;
  height: 14px;
  flex-shrink: 0;
}
.wr-stepper__title {
  font-family: var(--font-display, "Plus Jakarta Sans", sans-serif);
  font-size: 26px;
  font-weight: 700;
  color: var(--ink);
  letter-spacing: -0.02em;
  line-height: 1.28;
  margin: 0;
}
@media (min-width: 768px) {
  .wr-stepper__title {
    font-size: 33px;
  }
}
.wr-stepper__actions {
  display: flex;
  align-items: center;
  gap: 12px;
  align-self: flex-end;
}
@media (min-width: 640px) {
  .wr-stepper__actions {
    align-self: auto;
  }
}
.wr-stepper__save-status {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  color: var(--muted);
  padding: 5px 10px;
  border-radius: 12px;
  background: var(--surface-2);
  border: 1px solid var(--border);
}
.wr-stepper__save-status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--success);
  animation: wr-pulse 2s infinite;
  flex-shrink: 0;
}
.wr-stepper__save-status-spinner {
  width: 13px;
  height: 13px;
  color: var(--accent);
  animation: wr-spin 1s linear infinite;
  flex-shrink: 0;
}
.wr-stepper__save-status-saving {
  color: var(--accent);
  font-weight: 600;
}
.wr-stepper__history-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  font-weight: 600;
  padding: 6px 12px;
  border-radius: 12px;
  background: var(--surface-2);
  color: var(--ink-soft);
  border: 1px solid var(--border);
  cursor: pointer;
  transition: all 150ms cubic-bezier(0.4, 0, 0.2, 1);
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
}
.wr-stepper__history-btn svg {
  width: 15px;
  height: 15px;
  color: var(--primary);
  flex-shrink: 0;
}
.wr-stepper__history-btn:hover {
  background: var(--primary-tint);
  color: var(--primary);
  border-color: var(--primary);
}
.wr-stepper__progress-bar {
  width: 100%;
  height: 6px;
  background: var(--surface-2);
  border-radius: 999px;
  overflow: hidden;
  margin-bottom: 20px;
}
.wr-stepper__progress-fill {
  height: 100%;
  border-radius: 999px;
  background: linear-gradient(90deg, var(--primary), var(--success));
  transition: width 500ms cubic-bezier(0.4, 0, 0.2, 1);
}
.wr-stepper__steps {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
}
@media (min-width: 640px) {
  .wr-stepper__steps {
    grid-template-columns: repeat(3, 1fr);
  }
}
@media (min-width: 1024px) {
  .wr-stepper__steps {
    grid-template-columns: repeat(5, 1fr);
  }
}
.wr-stepper__step-pill {
  display: flex;
  flex-direction: column;
  text-align: left;
  padding: 10px;
  border-radius: 12px;
  border: 1px solid var(--border);
  background: var(--surface-2);
  color: var(--muted);
  cursor: pointer;
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
  transition: all 150ms cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}
.wr-stepper__step-pill:hover {
  background: var(--surface);
  border-color: var(--primary);
}
.wr-stepper__step-pill--active {
  background: var(--primary-tint);
  border-color: var(--primary);
  color: var(--primary);
  box-shadow: 0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent);
}
.wr-stepper__step-pill--done {
  background: var(--surface);
  border-color: color-mix(in srgb, var(--success) 40%, transparent);
  color: var(--ink-soft);
}
.wr-stepper__step-pill--done .wr-stepper__step-num {
  background: var(--success);
  color: #fff;
}
.wr-stepper__step-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 5px;
}
.wr-stepper__step-num {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  font-size: 11px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--border);
  color: var(--ink-soft);
  transition: background 150ms cubic-bezier(0.4, 0, 0.2, 1), color 150ms cubic-bezier(0.4, 0, 0.2, 1);
}
.wr-stepper__step-pill--active .wr-stepper__step-num {
  background: var(--primary);
  color: #fff;
}
.wr-stepper__step-time {
  font-size: 10px;
  font-family: var(--font-mono, "JetBrains Mono", monospace);
  color: var(--muted);
}
.wr-stepper__step-title {
  font-size: 12px;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.wr-stepper__step-subtitle {
  font-size: 10px;
  color: var(--muted);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-top: 2px;
}

.wr-evidence {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 16px;
  border-radius: 12px;
  background: var(--primary-tint);
