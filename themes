  border: 1px solid var(--border);
  color: var(--ink-soft);
}
.confirm-dialog-btn.cancel:hover {
  border-color: var(--primary);
  color: var(--primary-dark);
}
.confirm-dialog-btn.cancel:focus-visible {
  outline: 2px solid var(--primary);
  outline-offset: 2px;
}

.confirm-dialog-btn.confirm {
  background: var(--primary);
  color: #fff;
}
.confirm-dialog-btn.confirm:hover {
  filter: brightness(1.06);
}
.confirm-dialog-btn.confirm:focus-visible {
  outline: 2px solid var(--primary-dark);
  outline-offset: 2px;
}
.confirm-dialog-btn.confirm.danger {
  background: var(--destructive);
}
.confirm-dialog-btn.confirm.danger:hover {
  filter: brightness(1.06);
}
.confirm-dialog-btn.confirm.danger:focus-visible {
  outline-color: var(--destructive);
}

