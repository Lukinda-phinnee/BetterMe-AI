.wr-mb {
  margin-bottom: 16px;
}

.wr-wellbeing-stack {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.wr-icon-sm {
  width: 16px;
  height: 16px;
}

@keyframes wr-skeleton-wave {
  0% {
    background-position: -600px 0;
  }
  100% {
    background-position: 600px 0;
  }
}
.wr-skeleton {
  background: linear-gradient(90deg, var(--surface-2) 25%, color-mix(in srgb, var(--border) 60%, var(--surface-2)) 50%, var(--surface-2) 75%);
  background-size: 600px 100%;
  animation: wr-skeleton-wave 1.4s ease-in-out infinite;
  border-radius: 12px;
}
.wr-skeleton--text {
  height: 14px;
  border-radius: 999px;
}
.wr-skeleton--title {
  height: 22px;
  border-radius: 999px;
}
.wr-skeleton--block {
  height: 80px;
}
.wr-skeleton--card {
  height: 120px;
}
.wr-skeleton--pill {
  height: 44px;
  border-radius: 12px;
}

.wr-loading-page {
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 24px;
}
.wr-loading-page__header {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.wr-loading-page__title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.wr-loading-page__pills {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 10px;
}
@media (max-width: 1024px) {
  .wr-loading-page__pills {
    grid-template-columns: repeat(3, 1fr);
  }
}
.wr-loading-page__body {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
}
@media (max-width: 768px) {
  .wr-loading-page__body {
    grid-template-columns: 1fr;
  }
}
.wr-loading-page__card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.wr-error-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  text-align: center;
  padding: 32px;
}
.wr-error-page__icon {
  font-size: 48px;
  margin-bottom: 20px;
  line-height: 1;
}
.wr-error-page__title {
  font-size: 20px;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 12px;
}
.wr-error-page__body {
  font-size: 12px;
  color: var(--muted);
  max-width: 380px;
  line-height: 1.6;
  margin-bottom: 20px;
}

.wr-empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48px 24px;
  border: 1.5px dashed var(--border);
  border-radius: 18px;
  text-align: center;
}
.wr-empty-state__icon {
  font-size: 32px;
  margin-bottom: 16px;
  line-height: 1;
  opacity: 0.7;
}
.wr-empty-state__title {
  font-size: 12px;
  font-weight: 600;
  color: var(--ink-soft);
  margin-bottom: 4px;
}
.wr-empty-state__body {
  font-size: 11px;
  color: var(--muted);
  line-height: 1.6;
}
