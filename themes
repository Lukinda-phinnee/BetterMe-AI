}

.goal-history-sidebar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 24px;
  border-bottom: 1px solid var(--border);
  background-color: var(--surface);
  height: 64px;
  flex-shrink: 0;
}
.goal-history-sidebar-header h3 {
  font-size: 14px;
  font-weight: 600;
  color: var(--ink);
  margin: 0;
  white-space: nowrap;
}

.goal-history-toggle-btn {
  width: 28px;
  height: 28px;
  border-radius: 6px;
  border: 1px solid var(--border);
  background: var(--surface-2);
  color: var(--ink-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  flex-shrink: 0;
  transition: all 0.2s;
}
.goal-history-toggle-btn:hover {
  background: var(--border);
  color: var(--ink);
}

.goal-history-new-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 14px;
  margin: 12px 10px 6px;
  border-radius: 8px;
  border: 1px dashed var(--border);
  background: transparent;
  color: var(--ink-soft);
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
  font-family: var(--font-body, inherit);
  white-space: nowrap;
}
.goal-history-new-btn:hover {
  border-color: var(--primary);
  color: var(--primary);
  background: var(--primary-tint);
}

.goal-history-list {
  flex: 1;
  overflow-y: auto;
  padding: 6px 8px;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.goal-history-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 9px 10px;
  border-radius: 8px;
  border: none;
  background: transparent;
  cursor: pointer;
  text-align: left;
  width: 100%;
  transition: background 0.15s;
  color: var(--ink);
  position: relative;
}
.goal-history-item:hover {
  background: var(--surface-2);
}
.goal-history-item:hover .goal-history-item-actions {
  opacity: 1;
}
.goal-history-item.active {
  background: var(--primary-tint);
}
.goal-history-item.active .goal-history-item-title {
  color: var(--primary);
  font-weight: 600;
}

.goal-history-item-actions {
  display: flex;
  align-items: center;
  gap: 2px;
  flex-shrink: 0;
  margin-left: auto;
  opacity: 0;
  transition: opacity 0.15s ease;
}

.goal-history-item-rename {
  padding: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  border-radius: 6px;
  background: transparent;
  color: var(--ink-soft);
  cursor: pointer;
  transition: background 0.15s ease, color 0.15s ease;
}
.goal-history-item-rename:hover {
  background: var(--primary-tint);
  color: var(--primary);
}

.goal-history-item-delete {
  padding: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  border-radius: 6px;
  background: transparent;
  color: var(--ink-soft);
  cursor: pointer;
  transition: background 0.15s ease, color 0.15s ease;
}
.goal-history-item-delete:hover {
  background: rgba(239, 68, 68, 0.1);
  color: #ef4444;
}

.goal-history-item-edit {
  display: flex;
  align-items: center;
  gap: 6px;
  width: 100%;
}

.goal-history-item-edit-input {
  flex: 1;
  min-width: 0;
  padding: 4px 8px;
  font-size: 13px;
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
  border: 1.5px solid var(--primary);
  border-radius: 6px;
  outline: none;
  background: var(--surface);
  color: var(--ink);
}

.goal-history-item-edit-confirm {
  flex-shrink: 0;
  padding: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  border-radius: 6px;
  background: var(--primary-tint);
  color: var(--primary);
  cursor: pointer;
  transition: background 0.15s ease, color 0.15s ease;
}
.goal-history-item-edit-confirm:hover {
  background: var(--primary);
  color: #fff;
}

.goal-history-item-icon {
  flex-shrink: 0;
  color: var(--ink-soft);
}

.goal-history-item-text {
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 0;
  flex: 1 1 auto;
  overflow: hidden;
}

.goal-history-item-title {
  font-size: 13px;
  font-weight: 500;
  color: var(--ink);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.goal-history-item-time {
  font-size: 11px;
  color: var(--muted);
}

.goal-history-loading {
  display: flex;
  gap: 4px;
  justify-content: center;
  padding: 16px;
}
.goal-history-loading span {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--primary);
  animation: pulseDot 1.2s infinite;
}
.goal-history-loading span:nth-child(2) {
  animation-delay: 0.2s;
}
.goal-history-loading span:nth-child(3) {
  animation-delay: 0.4s;
}

.goal-history-empty {
  padding: 16px;
  font-size: 12px;
  color: var(--muted);
  text-align: center;
}

@keyframes pulseDot {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}
.goal-chat-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  position: relative;
}

.goal-chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 24px;
  background-color: var(--surface);
  z-index: 10;
  height: 64px;
  transition: all 0.3s ease;
}
.goal-chat-header.welcome {
  border-bottom: none;
}
.goal-chat-header.active {
  border-bottom: 1px solid var(--border);
}

.goal-chat-header-left {
  display: flex;
  align-items: center;
  gap: 8px;
}

.goal-chat-header-right {
  display: flex;
  align-items: center;
  gap: 12px;
}

.goal-chat-menu-btn {
  width: 40px;
  height: 40px;
  border-radius: 8px;
  border: 1px solid var(--border);
  background-color: var(--surface-2);
  color: var(--ink-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s;
}
.goal-chat-menu-btn:hover {
  background-color: var(--border);
  color: var(--ink);
}

.goal-chat-add-goal-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 16px;
  border-radius: 8px;
  border: 1px solid var(--primary);
  background-color: var(--primary);
  color: #fff;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
}
.goal-chat-add-goal-btn:hover {
  background-color: var(--primary-dark);
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
}
.goal-chat-add-goal-btn:active {
  transform: translateY(0);
}
.goal-chat-add-goal-btn svg {
  stroke: currentColor;
}

.goal-chat-logo-icon {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
}

.goal-chat-title-group h2 {
  font-size: 16px;
  font-weight: 600;
  margin: 0;
  line-height: 1;
}
.goal-chat-title-group span {
  font-size: 11px;
  color: var(--muted);
}

.goal-chat-reset-btn {
  padding: 6px 12px;
  border-radius: 999px;
  border: 1px solid var(--border);
  background-color: var(--surface-2);
  font-size: 12px;
  font-weight: 500;
  color: var(--ink-soft);
  display: flex;
  align-items: center;
  gap: 6px;
  cursor: pointer;
  transition: all 0.2s;
}
.goal-chat-reset-btn:hover {
  background-color: var(--border);
  color: var(--ink);
}

.goal-chat-history {
  flex: 1;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow-y: auto;
  padding-bottom: 180px;
}

.goal-chat-messages-container {
  width: 100%;
  margin: 0 auto;
  padding: 32px 24px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.goal-chat-welcome {
  text-align: center;
  padding: 60px 24px 40px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}
.goal-chat-welcome h3 {
  font-size: 22px;
  font-weight: 700;
  color: var(--ink);
  margin: 0;
}
.goal-chat-welcome p {
  font-size: 15px;
  color: var(--ink-soft);
  line-height: 1.6;
  max-width: 380px;
  margin: 0;
}

.goal-chat-welcome-icon {
  width: 56px;
  height: 56px;
  border-radius: 16px;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  margin-bottom: 4px;
}

.goal-chat-msg-row {
  display: flex;
  gap: 10px;
  align-items: flex-end;
  animation: fadeIn 0.25s ease-out;
  max-width: 100%;
}
.goal-chat-msg-row.user {
  display: flex;
  flex-direction: row;
  margin-left: auto;
  flex-wrap: nowrap;
  align-items: flex-end;
}
.goal-chat-msg-row.assistant {
  flex-direction: row;
  margin-right: auto;
}
.goal-chat-msg-row + .goal-chat-msg-row.user, .goal-chat-msg-row + .goal-chat-msg-row.assistant {
  margin-top: 4px;
}
.goal-chat-msg-row.user + .goal-chat-msg-row.assistant, .goal-chat-msg-row.assistant + .goal-chat-msg-row.user {
  margin-top: 16px;
}

.goal-chat-avatar {
  width: 30px;
  height: 30px;
  border-radius: 8px;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-bottom: 2px;
}

.goal-chat-bubble.user {
  background: var(--surface);
  color: var(--ink);
  padding: 10px 16px;
  border-radius: 18px 18px 4px 18px;
  font-size: 14.5px;
  line-height: 1.55;
  max-width: 560px;
  word-break: break-word;
  border: 1px solid var(--border);
  white-space: normal;
  display: inline-block;
}
.goal-chat-bubble.user span {
  display: inline !important;
  white-space: normal !important;
  word-break: break-word !important;
  writing-mode: horizontal-tb !important;
  text-orientation: mixed !important;
}
.goal-chat-bubble.assistant {
  background: transparent;
  color: var(--ink);
  font-size: 14.5px;
  line-height: 1.65;
  max-width: min(640px, 85%);
  padding: 0;
  border: none;
}
.goal-chat-bubble.typing {
  padding: 10px 16px;
  background: var(--surface-2);
  border-radius: 18px 18px 18px 4px;
}

[data-theme=dark] .goal-chat-bubble.user {
  background: #ffffff;
  color: #000000;
  border-color: rgba(255, 255, 255, 0.1);
}
[data-theme=dark] .goal-chat-bubble.assistant {
  color: #ffffff;
}

.goal-chat-msg-body p {
  margin: 0 0 6px;
}
.goal-chat-msg-body p:last-child {
  margin-bottom: 0;
}
.goal-chat-msg-body strong {
  font-weight: 600;
}

.goal-chat-msg-spacer {
  height: 6px;
}

.goal-chat-msg-list {
  margin: 4px 0 8px;
  padding-left: 20px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.goal-chat-msg-list li {
  font-size: 14.5px;
  line-height: 1.55;
  color: var(--ink);
}

.goal-chat-typing-container {
  display: flex;
  align-items: center;
  gap: 6px;
  height: 36px;
}

.goal-chat-input-outer-wrapper {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  left: 0;
  right: 0;
  padding: 24px;
  background: linear-gradient(to top, var(--bg) 60%, transparent);
  display: flex;
  justify-content: center;
  align-items: flex-end;
  z-index: 100;
  transition: top 0.3s ease, transform 0.3s ease;
}

.goal-chat-input-outer-wrapper.has-messages {
  top: auto;
  bottom: 0;
  transform: none;
  background: linear-gradient(to top, var(--bg) 80%, transparent);
  padding-bottom: 20px;
}

/* THE EXACT SPECIFIED INPUT COMPONENT STRUCTURE */
/* parent container has a dark background in light mode and white background in darkmode */
.goal-chat-input-parent-container {
  width: 100%;
  max-width: 800px;
  display: flex;
  flex-direction: column;
  box-shadow: var(--shadow);
  border-radius: 24px;
  border: 1px solid var(--border);
  overflow: hidden;
  padding: 8px;
  gap: 8px;
  /* light mode: parent has dark background */
  background-color: #1E293B;
  border-color: rgba(255, 255, 255, 0.1);
  /* dark mode: parent has white background */
}
[data-theme=dark] .goal-chat-input-parent-container {
  background-color: #FFFFFF;
  border-color: rgba(0, 0, 0, 0.1);
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
}

/* inside it comes the input field with different buttons */
.goal-chat-input-field-container {
  padding: 16px 20px 8px 20px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  border-radius: 16px 16px 8px 8px !important;
  /* Top input box has white background in light mode, and dark/surface background in dark mode */
  background-color: #FFFFFF;
  border-radius: 23px 23px 0 0;
}
[data-theme=dark] .goal-chat-input-field-container {
  background-color: #141322; /* Matches dark theme surface */
}

.goal-chat-textarea {
  width: 100%;
  border: none;
  outline: none;
  resize: none;
  font-size: 15px;
  line-height: 1.5;
  color: #0F172A; /* dark text for white background */
  background-color: transparent;
  font-family: inherit;
  max-height: 180px;
}
[data-theme=dark] .goal-chat-textarea {
  color: #F8FAFC; /* light text in dark mode */
}

.goal-chat-actions-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8px;
  padding-top: 8px;
}

.goal-chat-left-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}

.goal-chat-action-btn {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #64748B;
  cursor: pointer;
  transition: all 0.2s;
  background-color: transparent;
  border: none;
}
.goal-chat-action-btn:hover {
  background-color: #F1F5F9;
  color: #0F172A;
}
.goal-chat-action-btn.active {
  color: #4F46E5;
  background-color: #EEECFC;
}
[data-theme=dark] .goal-chat-action-btn {
  color: #94A3B8;
}
[data-theme=dark] .goal-chat-action-btn:hover {
  background-color: #211F36;
  color: #F8FAFC;
}
[data-theme=dark] .goal-chat-action-btn.active {
  color: #818CF8;
  background-color: #1E1B4B;
}

.goal-chat-submit-btn {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  border: none;
  /* submit button matching light mode styles */
  background-color: #E2E8F0;
  color: #94A3B8;
  cursor: default;
}
.goal-chat-submit-btn.active {
  background-color: #0F172A;
  color: #FFFFFF;
  cursor: pointer;
}
[data-theme=dark] .goal-chat-submit-btn {
  background-color: #29273E;
  color: #6A6687;
}
[data-theme=dark] .goal-chat-submit-btn.active {
  background-color: #FFFFFF;
  color: #141322;
  cursor: pointer;
}

/* below the input field comes another section */
.goal-chat-tray-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px;
  font-size: 12px;
  border-radius: 8px 8px 16px 16px !important;
  border: 1px solid gray !important;
  /* light mode styles (where parent has slate-blue background #1E293B) */
  color: #F8FAFC;
}
[data-theme=dark] .goal-chat-tray-container {
  /* dark mode styles (where parent has white background) */
  color: #0F172A;
  border-top: 1px solid rgba(0, 0, 0, 0.05);
}

.goal-chat-pill {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 4px 10px;
  border-radius: 999px;
  font-weight: 500;
  /* light mode: tray background is dark slate #1E293B, so pills are semi-translucent white */
  background-color: rgba(255, 255, 255, 0.1);
  color: #E2E8F0;
  border: 1px solid rgba(255, 255, 255, 0.05);
}
.goal-chat-pill.bold {
  font-weight: 600;
}
[data-theme=dark] .goal-chat-pill {
  /* dark mode: tray background is white, pills are semi-translucent dark slate */
  background-color: rgba(15, 23, 42, 0.08);
  color: #0F172A;
  border: 1px solid rgba(0, 0, 0, 0.05);
}

.goal-chat-pill-dots {
  display: flex;
  gap: 2px;
}
.goal-chat-pill-dots span:nth-child(1) {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background-color: #F59E0B;
}
.goal-chat-pill-dots span:nth-child(2) {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background-color: #EF4444;
}
.goal-chat-pill-dots span:nth-child(3) {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background-color: #3B82F6;
}

.goal-chat-tray-status {
  font-style: italic;
  margin-left: 12px;
  margin-right: auto;
  font-size: 11.5px;
  max-width: 300px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  /* light mode: status text is light gray */
  color: #94A3B8;
}
.goal-chat-tray-status.typing {
  animation: pulseText 1.5s infinite;
}
[data-theme=dark] .goal-chat-tray-status {
  /* dark mode: status text is dark gray */
  color: #64748B;
}

.goal-chat-stop-btn {
  padding: 4px 12px;
  border-radius: 6px;
  font-size: 11px;
  font-weight: 600;
  cursor: pointer;
  border: none;
  transition: background-color 0.2s;
  /* light mode */
  background-color: rgba(255, 255, 255, 0.15);
  color: #FFF;
}
.goal-chat-stop-btn:hover {
  background-color: rgba(255, 255, 255, 0.25);
}
[data-theme=dark] .goal-chat-stop-btn {
  /* dark mode */
  background-color: rgba(15, 23, 42, 0.08);
  color: #0F172A;
}
[data-theme=dark] .goal-chat-stop-btn:hover {
  background-color: rgba(15, 23, 42, 0.15);
}

/* ─── Input stack wrapper ──────────────────────────────────────────────────────
   Holds the input parent container + the guided panel as a centered column.
   Both share the same max-width so they stay aligned. Because the outer wrapper
   is bottom-anchored, adding the guided panel BELOW the input here causes the
   whole stack to grow upward — visually pushing the input up. */
.goal-chat-input-stack {
  width: 100%;
  max-width: 800px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

/* ─── Guided Q&A Panel ────────────────────────────────────────────────────────
   Same design language as .goal-chat-input-parent-container: dark slate in light
   mode, white in dark mode, 24px radius, border + shadow, 8px padding. */
.goal-chat-guided-panel {
  width: 100%;
  border-radius: 24px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  overflow: hidden;
  box-shadow: var(--shadow);
  /* light mode: matches parent container dark background */
  background-color: #1E293B;
  /* dark mode: matches parent container white background */
}
[data-theme=dark] .goal-chat-guided-panel {
  background-color: #FFFFFF;
  border-color: rgba(0, 0, 0, 0.1);
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
}

.goal-chat-guided-panel-inner {
  padding: 12px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

/* Step badge — pill showing which WOOP step we're on */
.goal-chat-guided-step-badge {
  display: inline-flex;
  align-self: flex-start;
  padding: 3px 12px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  /* light mode */
  background-color: rgba(99, 102, 241, 0.15);
  color: #A5B4FC;
  /* dark mode */
}
[data-theme=dark] .goal-chat-guided-step-badge {
  background-color: rgba(99, 102, 241, 0.12);
  color: #6366F1;
}

/* The question text */
.goal-chat-guided-question {
  font-size: 15px;
  font-weight: 500;
  line-height: 1.5;
  /* light mode: light text on dark panel */
  color: #F1F5F9;
  /* dark mode: dark text on white panel */
}
[data-theme=dark] .goal-chat-guided-question {
  color: #0F172A;
}

/* Numbered suggestion list with descriptions */
.goal-chat-guided-suggestions {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin: 12px 0;
}

.goal-chat-guided-suggestion-item {
  display: flex;
  gap: 12px;
  padding: 12px;
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.15s ease;
  border: 1px solid transparent;
  /* light mode: translucent white on dark panel */
