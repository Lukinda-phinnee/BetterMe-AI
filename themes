}
.wr-evidence--success .wr-evidence__title {
  color: var(--success);
}

.wr-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 20px;
  box-shadow: var(--shadow);
  transition: background 200ms cubic-bezier(0.4, 0, 0.2, 1), border-color 200ms cubic-bezier(0.4, 0, 0.2, 1);
}
.wr-card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
  flex-wrap: wrap;
  gap: 12px;
}
.wr-card__title {
  font-size: 15px;
  font-weight: 700;
  color: var(--ink);
  display: flex;
  align-items: center;
  gap: 8px;
  margin: 0;
}
.wr-card__title::before {
  content: "";
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--primary);
  flex-shrink: 0;
}
.wr-card__title--success::before {
  background: var(--success);
}
.wr-card__title--accent::before {
  background: var(--accent);
}
.wr-card__subtitle {
  font-size: 12px;
  color: var(--muted);
  margin-top: 3px;
}
.wr-card__badge {
  font-size: 11px;
  font-weight: 600;
  padding: 3px 10px;
  border-radius: 999px;
  background: var(--primary-tint);
  color: var(--primary);
  font-family: var(--font-mono, "JetBrains Mono", monospace);
}
.wr-card__badge--step {
  font-size: 10px;
  background: var(--surface-2);
  color: var(--muted);
}

.wr-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 24px;
}
@media (min-width: 768px) {
  .wr-grid--2col {
    grid-template-columns: 1fr 1fr;
  }
}
@media (min-width: 1024px) {
  .wr-grid--7-5 {
    grid-template-columns: 7fr 5fr;
  }
}

.wr-step {
  animation: wr-fade-in 280ms cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.wr-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20px;
  border-top: 1px solid var(--border);
}

.wr-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
  font-weight: 600;
  border-radius: 12px;
  cursor: pointer;
  transition: all 150ms cubic-bezier(0.4, 0, 0.2, 1);
  border: none;
  outline: none;
}
.wr-btn svg {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
}
.wr-btn--sm {
  font-size: 12px;
  padding: 6px 12px;
}
.wr-btn--md {
  font-size: 12px;
  padding: 8px 16px;
}
.wr-btn--lg {
  font-size: 15px;
  padding: 11px 24px;
}
.wr-btn--xl {
  font-size: 15px;
  padding: 13px 32px;
}
.wr-btn--ghost {
  background: var(--surface-2);
  color: var(--ink-soft);
  border: 1px solid var(--border);
}
.wr-btn--ghost:hover {
  background: var(--surface);
  color: var(--ink);
}
.wr-btn--primary {
  background: var(--primary);
  color: #fff;
  box-shadow: 0 4px 14px -2px color-mix(in srgb, var(--primary) 30%, transparent);
}
.wr-btn--primary:hover {
  filter: brightness(1.08);
}
.wr-btn--primary:active {
  transform: scale(0.98);
}
.wr-btn--success {
  background: var(--success);
  color: #fff;
  box-shadow: 0 4px 14px -2px color-mix(in srgb, var(--success) 30%, transparent);
}
.wr-btn--success:hover {
  filter: brightness(1.08);
}
.wr-btn--success:active {
  transform: scale(0.98);
}
.wr-btn--seal {
  background: linear-gradient(135deg, var(--success), var(--primary));
  color: #fff;
  font-weight: 700;
  font-size: 15px;
  padding: 14px 32px;
  border-radius: 12px;
  box-shadow: 0 8px 24px -4px color-mix(in srgb, var(--success) 35%, transparent);
}
.wr-btn--seal:hover {
  filter: brightness(1.07);
  transform: scale(1.01);
}
.wr-btn--seal:active {
  transform: scale(0.98);
}
.wr-btn--seal svg {
  width: 20px;
  height: 20px;
}
.wr-btn--ai {
  background: linear-gradient(135deg, var(--primary), color-mix(in srgb, var(--primary-dark) 80%, #7c3aed));
  color: #fff;
  font-weight: 700;
  box-shadow: 0 4px 14px -2px color-mix(in srgb, var(--primary) 30%, transparent);
}
.wr-btn--ai:hover {
  filter: brightness(1.08);
}
.wr-btn--ai:active {
  transform: scale(0.98);
}
.wr-btn--danger {
  background: color-mix(in srgb, var(--destructive) 12%, transparent);
  color: var(--destructive);
  border: 1px solid color-mix(in srgb, var(--destructive) 25%, transparent);
}
.wr-btn--danger:hover {
  background: color-mix(in srgb, var(--destructive) 20%, transparent);
}
.wr-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none !important;
  filter: none !important;
}

.wr-input-row {
  display: flex;
  gap: 12px;
}

.wr-input,
.wr-textarea {
  width: 100%;
  background: var(--surface-2);
  border: 1.5px solid var(--border);
  border-radius: 12px;
  padding: 10px 14px;
  font-size: 12px;
  color: var(--ink);
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
  outline: none;
  transition: border-color 150ms cubic-bezier(0.4, 0, 0.2, 1), box-shadow 150ms cubic-bezier(0.4, 0, 0.2, 1), background 200ms cubic-bezier(0.4, 0, 0.2, 1);
}
.wr-input::placeholder,
.wr-textarea::placeholder {
  color: var(--muted);
}
.wr-input:focus,
.wr-textarea:focus {
  border-color: var(--primary);
  background: var(--surface);
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--primary) 12%, transparent);
}
.wr-input--accent:focus,
.wr-textarea--accent:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 12%, transparent);
}
.wr-input--success:focus,
.wr-textarea--success:focus {
  border-color: var(--success);
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--success) 12%, transparent);
}

.wr-textarea {
