@charset "UTF-8";
:root {
  --bg: #F3F3FA;
  --surface: #FFFFFF;
  --surface-2: #F0EFF8;
  --ink: #0E0D1B;
  --ink-soft: #595675;
  --muted: #8E8AA8;
  --border: #E5E3F0;
  --primary: #4F46E5;
  --primary-dark: #3B32C4;
  --primary-tint: #EEECFC;
  --accent: #F59E0B;
  --accent-tint: #FEF3C7;
  --destructive: #EF4444;
  --success: #10B981;
  --shadow: 0 10px 25px -5px rgba(14, 13, 27, 0.04), 0 8px 10px -6px rgba(14, 13, 27, 0.04);
  --font-display: Plus Jakarta Sans, sans-serif;
  --font-body: Plus Jakarta Sans, sans-serif;
  --font-mono: JetBrains Mono, monospace;
}

[data-theme=dark] {
  --bg: #0A0912;
  --surface: #141322;
  --surface-2: #211F36;
  --ink: #F5F5FA;
  --ink-soft: #A3A0BD;
  --muted: #6A6687;
  --border: #29273E;
  --primary: #6366F1;
  --primary-dark: #818CF8;
  --primary-tint: #1E1B4B;
  --accent: #FBBF24;
  --accent-tint: #78350F;
  --destructive: #F87171;
  --success: #34D399;
  --shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.45), 0 8px 10px -6px rgba(0, 0, 0, 0.45);
}

@media (prefers-color-scheme: dark) {
  :root:not([data-theme=light]) {
    --bg: #0A0912;
    --surface: #141322;
    --surface-2: #211F36;
    --ink: #F5F5FA;
    --ink-soft: #A3A0BD;
    --muted: #6A6687;
    --border: #29273E;
    --primary: #6366F1;
    --primary-dark: #818CF8;
    --primary-tint: #1E1B4B;
    --accent: #FBBF24;
    --accent-tint: #78350F;
    --destructive: #F87171;
    --success: #34D399;
    --shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.45), 0 8px 10px -6px rgba(0, 0, 0, 0.45);
  }
}
* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html,
body {
  height: 100%;
}

body {
  background-color: var(--bg);
  color: var(--ink);
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  line-height: 1.5;
}

h1,
h2,
h3,
h4,
h5,
h6 {
  font-family: var(--font-display, "Plus Jakarta Sans", sans-serif);
  font-weight: 500;
  letter-spacing: -0.01em;
  line-height: 1.28;
}

h1 {
  font-size: 33px;
}

h2 {
  font-size: 26px;
}

h3 {
  font-size: 20px;
}

p {
  margin: 0;
}

a {
  color: inherit;
  text-decoration: none;
}

button {
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
  cursor: pointer;
  border: none;
  background: none;
}

input {
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
}

.auth-wrapper {
  display: flex;
  min-height: 100vh;
  width: 100%;
  background: var(--bg);
  position: relative;
  overflow: hidden;
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
}

.auth-wrapper::before {
  content: "";
  position: fixed;
  top: -20%;
  left: -10%;
  width: 600px;
  height: 600px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(99, 102, 241, 0.12) 0%, transparent 70%);
  pointer-events: none;
  animation: float-orb 12s ease-in-out infinite;
}

.auth-wrapper::after {
  content: "";
  position: fixed;
  bottom: -20%;
  right: -10%;
  width: 500px;
  height: 500px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(139, 92, 246, 0.1) 0%, transparent 70%);
  pointer-events: none;
  animation: float-orb 16s ease-in-out infinite reverse;
}

@keyframes float-orb {
  0%, 100% {
    transform: translate(0, 0) scale(1);
  }
  33% {
    transform: translate(30px, -20px) scale(1.05);
  }
  66% {
    transform: translate(-20px, 30px) scale(0.95);
  }
}
.brand-panel {
  flex: 0 0 42%;
  background: linear-gradient(145deg, #4F46E5 0%, #7C3AED 50%, #6366F1 100%);
  color: #fff;
  padding: 48px 52px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  position: relative;
  overflow: hidden;
}
.brand-panel::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23fff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
}
.brand-panel::after {
  content: "";
  position: absolute;
  top: -80px;
  right: -80px;
  width: 320px;
  height: 320px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  pointer-events: none;
}

.brand-panel-deco {
  position: absolute;
  bottom: -60px;
  left: -60px;
  width: 260px;
  height: 260px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
  pointer-events: none;
}

.brand-panel-top {
  display: flex;
  align-items: center;
  gap: 12px;
  position: relative;
  z-index: 1;
}

.brand-mark {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  background: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.brand-mark svg {
  width: 22px;
  height: 22px;
}

.brand-name {
  font-family: var(--font-display, "Plus Jakarta Sans", sans-serif);
  font-size: 22px;
  font-weight: 800;
  letter-spacing: -0.03em;
}

.brand-panel-mid {
  position: relative;
  z-index: 1;
  max-width: 380px;
}

.brand-eyebrow {
  display: inline-block;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: rgba(255, 255, 255, 0.65);
  font-weight: 700;
  margin-bottom: 18px;
  padding: 5px 12px;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.15);
}

.brand-headline {
  font-size: 36px;
  line-height: 1.18;
  font-weight: 800;
  margin-bottom: 18px;
  letter-spacing: -0.03em;
}

.brand-sub {
  font-size: 15px;
  line-height: 1.65;
  color: rgba(255, 255, 255, 0.78);
  font-weight: 400;
}

.brand-features {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 32px;
}

.brand-feature {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 13.5px;
  color: rgba(255, 255, 255, 0.88);
  font-weight: 500;
}

.brand-feature-icon {
  width: 32px;
  height: 32px;
  border-radius: 10px;
  background: rgba(255, 255, 255, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.brand-feature-icon svg {
  width: 16px;
  height: 16px;
  stroke: #fff;
  stroke-width: 2;
  fill: none;
}

.brand-panel-bottom {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 12.5px;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.5;
}

.brand-panel-bottom::before {
  content: "★★★★★";
  color: rgba(255, 255, 255, 0.6);
  font-size: 11px;
  letter-spacing: 2px;
  display: block;
  margin-bottom: 4px;
}

.form-panel {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32px 40px;
  background: var(--bg);
  position: relative;
  z-index: 1;
  position: relative;
}

.form-card {
  width: 100%;
  max-width: 460px;
  padding: 16px;
  background: var(--surface);
  border-radius: 20px;
  border: 1px solid var(--border);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
}

.theme-toggle {
  position: absolute;
  top: 16px;
  right: 16px;
  width: 38px;
  height: 38px;
  border: 1px solid var(--border);
  background: var(--surface);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 200ms ease;
  color: var(--muted);
  z-index: 10;
  box-shadow: 0 2px 8px rgba(14, 13, 27, 0.02);
}
.theme-toggle:hover {
  border-color: var(--primary);
  color: var(--primary);
  background: var(--primary-tint);
}
.theme-toggle:active {
  transform: scale(0.9);
}
.theme-toggle svg {
  width: 17px;
  height: 17px;
  stroke: currentColor;
  stroke-width: 2;
  fill: none;
}

.tabs {
  display: flex;
  background: var(--surface-2);
  border-radius: 16px;
  padding: 4px;
  margin-bottom: 32px;
  border: 1px solid var(--border);
  gap: 4px;
}
.tabs button {
  flex: 1;
  border: none;
  background: transparent;
  padding: 11px 0;
  border-radius: 12px;
  font-size: 13.5px;
  font-weight: 600;
  color: var(--muted);
  transition: all 200ms ease;
  cursor: pointer;
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
  letter-spacing: -0.01em;
}
.tabs button.active {
  background: var(--surface);
  color: var(--primary);
  box-shadow: 0 10px 25px -5px rgba(14, 13, 27, 0.04), 0 8px 10px -6px rgba(14, 13, 27, 0.04);
  font-weight: 700;
}
.tabs button:not(.active):hover {
  color: var(--ink);
  background: rgba(79, 70, 229, 0.04);
}
.tabs button:active {
  transform: scale(0.97);
}

.form-view {
  display: none;
}
.form-view.active {
  display: block;
}

.form-head {
  margin-bottom: 28px;
  text-align: center;
}
.form-head h1 {
  font-size: 26px;
  margin-bottom: 6px;
  font-weight: 800;
  letter-spacing: -0.03em;
  color: var(--ink);
  line-height: 1.2;
}
.form-head .sub {
  color: var(--muted);
  font-size: 14px;
  line-height: 1.55;
}

.field {
  margin-bottom: 18px;
}
.field label {
  display: block;
  font-size: 12.5px;
  font-weight: 600;
  color: var(--ink-soft);
  margin-bottom: 7px;
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
  letter-spacing: 0.01em;
  text-transform: uppercase;
}
.field .input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}
.field .input-wrapper .input-icon {
  position: absolute;
  left: 15px;
  width: 17px;
  height: 17px;
  color: var(--muted);
  stroke: currentColor;
  pointer-events: none;
  transition: color 200ms ease;
  stroke-width: 2;
  fill: none;
}
.field .input-wrapper input {
  width: 100%;
  border: 1.5px solid var(--border);
  border-radius: 14px;
  padding: 14px 44px 14px 44px;
  font-size: 14px;
  outline: none;
  background: var(--surface);
  color: var(--ink);
  transition: border-color 200ms ease, box-shadow 200ms ease, background 200ms ease;
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
}
.field .input-wrapper input:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
  background: var(--surface);
}
.field .input-wrapper input::placeholder {
  color: var(--muted);
  opacity: 0.7;
}
.field .input-wrapper .password-toggle {
  position: absolute;
  right: 14px;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--muted);
  padding: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6px;
  transition: color 200ms ease, background 200ms ease;
}
.field .input-wrapper .password-toggle:hover {
  color: var(--primary);
  background: var(--primary-tint);
}
.field .input-wrapper .password-toggle svg {
  width: 17px;
  height: 17px;
  stroke: currentColor;
  fill: none;
  stroke-width: 2;
}
.field .input-wrapper:focus-within .input-icon {
  color: var(--primary);
}
.field .field-hint {
  font-size: 11.5px;
  color: var(--muted);
  margin-top: 6px;
  line-height: 1.45;
  padding-left: 2px;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24px;
}

.remember {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13.5px;
  color: var(--ink-soft);
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
  cursor: pointer;
}
.remember input[type=checkbox] {
  width: 16px;
  height: 16px;
  accent-color: var(--primary);
  cursor: pointer;
  border-radius: 4px;
}

.link-sm {
  font-size: 13.5px;
  color: var(--primary);
  font-weight: 600;
  background: none;
  border: none;
  text-decoration: none;
  cursor: pointer;
  padding: 0;
  transition: color 200ms ease;
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
}
.link-sm:hover {
  color: var(--primary-dark);
  text-decoration: underline;
}

.btn-primary {
  width: 100%;
  border: none;
  background: linear-gradient(135deg, #4F46E5, #7C3AED);
  color: #fff;
  padding: 15px 0;
  border-radius: 14px;
  font-size: 15px;
  font-weight: 700;
  letter-spacing: -0.01em;
  box-shadow: 0 8px 20px rgba(79, 70, 229, 0.3);
  transition: all 200ms ease;
  cursor: pointer;
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
  position: relative;
  overflow: hidden;
}
.btn-primary::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.08) 0%, transparent 100%);
  pointer-events: none;
}
.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 28px rgba(79, 70, 229, 0.42);
  filter: brightness(1.06);
}
.btn-primary:active {
  transform: translateY(0);
  box-shadow: 0 6px 16px rgba(79, 70, 229, 0.28);
}
.btn-primary:disabled {
  opacity: 0.55;
  cursor: not-allowed;
  transform: none;
  box-shadow: none;
}

.divider {
  display: flex;
  align-items: center;
  gap: 14px;
  margin: 24px 0;
  color: var(--muted);
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
}
.divider::before, .divider::after {
  content: "";
  flex: 1;
  height: 1px;
  background: var(--border);
}

.oauth-row {
  display: flex;
  gap: 12px;
}

.oauth-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 9px;
  border: 1.5px solid var(--border);
  background: var(--surface);
  border-radius: 14px;
  padding: 13px 0;
  font-size: 14px;
  font-weight: 600;
  color: var(--ink-soft);
  transition: all 200ms ease;
  cursor: pointer;
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
  box-shadow: 0 2px 8px rgba(14, 13, 27, 0.02);
}
.oauth-btn:hover {
  border-color: var(--primary);
  color: var(--ink);
  background: var(--primary-tint);
  transform: translateY(-1px);
  box-shadow: 0 10px 25px -5px rgba(14, 13, 27, 0.04), 0 8px 10px -6px rgba(14, 13, 27, 0.04);
}
.oauth-btn:active {
  transform: translateY(0);
}
.oauth-btn svg {
  width: 18px;
  height: 18px;
}

.foot-note {
  text-align: center;
  font-size: 13.5px;
  color: var(--muted);
  margin-top: 24px;
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
  line-height: 1.5;
}

.legal-note {
  font-size: 11.5px;
  color: var(--muted);
  line-height: 1.55;
  margin-top: 18px;
  text-align: center;
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
}

.error-message {
  margin-bottom: 18px;
  padding: 13px 16px;
  background: rgba(239, 68, 68, 0.07);
  border: 1px solid rgba(239, 68, 68, 0.2);
  border-radius: 12px;
  color: #EF4444;
  font-size: 13.5px;
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
  line-height: 1.45;
  display: flex;
  align-items: flex-start;
  gap: 10px;
}
.error-message::before {
  content: "⚠";
  flex-shrink: 0;
  font-size: 14px;
  margin-top: 1px;
}

.success-message {
  margin-bottom: 18px;
  padding: 13px 16px;
  background: rgba(16, 185, 129, 0.07);
  border: 1px solid rgba(16, 185, 129, 0.2);
  border-radius: 12px;
  color: #10B981;
  font-size: 13.5px;
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
  line-height: 1.45;
  display: flex;
  align-items: flex-start;
  gap: 10px;
}
.success-message::before {
  content: "✓";
  flex-shrink: 0;
  font-size: 14px;
  font-weight: 700;
  margin-top: 1px;
}

.password-strength {
  display: flex;
  gap: 4px;
  margin-top: 8px;
}

.strength-bar {
  flex: 1;
  height: 3px;
  border-radius: 99px;
  background: var(--border);
  transition: background 300ms ease;
}
.strength-bar.weak {
  background: #EF4444;
}
.strength-bar.medium {
  background: #F59E0B;
}
.strength-bar.strong {
  background: #10B981;
}

.intent-toggle {
  display: flex;
  gap: 12px;
  margin-bottom: 24px;
}

.intent-card {
  flex: 1;
  border: 1.5px solid var(--border);
  border-radius: 14px;
  padding: 16px;
  cursor: pointer;
  transition: all 200ms ease;
  background: var(--surface);
}
.intent-card.active {
  border-color: var(--primary);
  background: var(--primary-tint);
  box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
}
.intent-card .it-title {
  font-size: 13.5px;
  font-weight: 700;
  margin-bottom: 3px;
  color: var(--ink);
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
}
.intent-card .it-sub {
  font-size: 12px;
  color: var(--muted);
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
}
.intent-card.active .it-sub {
  color: var(--primary);
}
.intent-card:hover:not(.active) {
  border-color: var(--primary);
  transform: translateY(-1px);
}

@media (max-width: 900px) {
  .brand-panel {
    display: none;
  }
  .form-panel {
    padding: 24px 32px;
  }
}
@media (max-width: 520px) {
  .form-panel {
    padding: 20px 16px;
  }
  .form-card {
    max-width: 100%;
    padding-top: 44px;
  }
  .brand-headline {
    font-size: 28px;
  }
}
[data-theme=dark] .brand-panel {
  background: linear-gradient(145deg, #3730A3 0%, #5B21B6 50%, #4338CA 100%);
}
[data-theme=dark] .btn-primary {
  background: linear-gradient(135deg, #6366F1, #8B5CF6);
  box-shadow: 0 8px 20px rgba(99, 102, 241, 0.35);
}
[data-theme=dark] .btn-primary:hover {
  box-shadow: 0 12px 28px rgba(99, 102, 241, 0.5);
}
[data-theme=dark] .field .input-wrapper input {
  background: var(--surface-2);
}
[data-theme=dark] .field .input-wrapper input:focus {
  background: var(--surface);
  box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.15);
}
[data-theme=dark] .oauth-btn {
  background: var(--surface-2);
}
[data-theme=dark] .oauth-btn:hover {
  background: var(--surface);
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}
* {
  scrollbar-width: thin;
  scrollbar-color: var(--border) var(--surface);
}

*::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

*::-webkit-scrollbar-track {
  background: var(--surface);
  border-radius: 4px;
}

*::-webkit-scrollbar-thumb {
  background: var(--border);
  border-radius: 4px;
  transition: background 200ms cubic-bezier(0.4, 0, 0.2, 1);
}

*::-webkit-scrollbar-thumb:hover {
  background: var(--muted);
}

