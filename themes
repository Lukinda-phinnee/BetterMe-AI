  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.25);
  border-color: var(--primary);
}

.user-profile-btn:active {
  transform: translateY(0);
}

.user-profile-menu {
  position: absolute;
  top: calc(100% + 12px);
  right: 0;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  box-shadow: var(--shadow-lg);
  min-width: 200px;
  display: none;
  z-index: 100;
  animation: fadeIn 200ms cubic-bezier(0.4, 0, 0.2, 1);
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(-4px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}
.user-profile-menu.open {
  display: block;
}

.user-profile-menu-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  color: var(--ink);
  font-size: 14px;
  cursor: pointer;
  transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
  font-weight: 500;
}

.user-profile-menu-item:hover {
  background: var(--surface-2);
}

.user-profile-menu-item:first-child {
  border-radius: 12px 12px 0 0;
}

.user-profile-menu-item:last-child {
  border-radius: 0 0 12px 12px;
}

.user-profile-menu-item svg {
  width: 18px;
  height: 18px;
  stroke: currentColor;
  stroke-width: 1.5;
  color: var(--ink-soft);
}

.user-profile-menu-item:hover svg {
  color: var(--primary);
}

.user-profile-menu-divider {
  height: 1px;
  background: var(--border);
  margin: 4px 0;
}

.screen {
  display: none;
  padding: 0;
}

.screen.active {
  display: block;
}

.card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg, 24px);
  padding: 20px;
  box-shadow: var(--shadow);
  transition: box-shadow 200ms cubic-bezier(0.4, 0, 0.2, 1), border-color 200ms cubic-bezier(0.4, 0, 0.2, 1);
}

.ring-wrap {
  position: relative;
  width: 64px;
  height: 64px;
  flex-shrink: 0;
}

.ring-wrap svg {
  transform: rotate(-90deg);
  width: 64px;
  height: 64px;
}

.ring-track {
  fill: none;
  stroke: var(--surface-2);
  stroke-width: 6;
}

.ring-progress {
  fill: none;
  stroke: var(--accent);
  stroke-width: 6;
  stroke-linecap: round;
  transition: stroke-dashoffset 1s ease;
}

.ring-label {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-mono, "JetBrains Mono", monospace);
  font-size: 13px;
  font-weight: 500;
  color: var(--ink);
}

.dash-grid {
  display: grid;
  grid-template-columns: 2fr 0.8fr;
  gap: 12px;
  padding: 12px;
}

.myday-cols {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
}

.myday-cols:not(.show-review) {
  grid-template-columns: repeat(3, 1fr);
}

.myday-col-card {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px;
  border: 2px solid var(--border);
  border-radius: 12px;
  background: var(--surface);
  transition: all 0.2s ease;
}

.myday-col-card.hidden {
  display: none;
}

.myday-col-card.todo {
  background: var(--primary);
  border-color: transparent;
}

.myday-col-card.todo .myday-col-icon svg,
.myday-col-card.todo .myday-col-name,
.myday-col-card.todo .myday-col-count {
  stroke: #fff;
  color: #fff;
}

.myday-col-icon {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.myday-col-icon svg {
  width: 24px;
  height: 24px;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.myday-col-card.todo .myday-col-icon svg {
  stroke: #fff;
}

.myday-col-card.inProgress .myday-col-icon svg {
  stroke: #f59e0b;
}

.myday-col-card.review .myday-col-icon svg {
  stroke: #8b5cf6;
}

.myday-col-card.done .myday-col-icon svg {
  stroke: #22c55e;
}

.myday-col-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.myday-col-name {
  font-size: 12px;
  font-weight: 500;
  color: var(--ink);
}

.myday-col-count {
  font-size: 20px;
  font-weight: 700;
  color: var(--ink);
}

.nearest-tasks-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}

.nearest-task-card {
  display: flex;
  flex-direction: column;
  padding: 12px;
  border-radius: 12px;
  background: var(--surface);
  border: 1px solid var(--border);
  transition: all 0.2s ease;
}

.nearest-task-card:hover {
  border-color: var(--primary);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.nearest-task-left {
  display: flex;
  align-items: flex-start;
  flex: 1;
  gap: 12px;
}

.nearest-task-title {
  font-size: 14px;
  font-weight: 500;
  color: var(--ink);
  margin-bottom: 4px;
}

.nearest-task-title.done {
  text-decoration: line-through;
  color: var(--muted);
}

.nearest-task-description {
  font-size: 12px;
  color: var(--muted);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 6px;
}

.nearest-task-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  margin-top: 8px;
}

.nearest-task-due {
  font-size: 12px;
  color: var(--primary);
  font-weight: 500;
  display: flex;
  align-items: center;
}

.schedule-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.schedule-item {
  display: grid;
  grid-template-columns: 80px 1fr;
  gap: 12px;
  align-items: flex-start;
  padding: 8px 0;
}

.schedule-time {
  font-size: 12px;
  font-weight: 600;
  color: var(--primary);
  padding-top: 4px;
}

.schedule-activity-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  border-radius: var(--radius-sm, 12px);
  position: relative;
  overflow: hidden;
  border-left: 4px solid transparent;
  transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
  background-color: var(--surface-2) !important;
  border: 1px solid var(--border);
  margin-bottom: 2px;
}
.schedule-activity-card:first-child {
  border-left-color: var(--primary);
  background-color: var(--primary-tint) !important;
  border-color: var(--primary-tint);
}
.schedule-activity-card:first-child .schedule-activity-name {
  color: var(--primary);
  font-weight: 600;
}
.schedule-activity-card:first-child .schedule-activity-duration {
  color: var(--primary);
  opacity: 0.8;
}

.schedule-activity-name {
  font-size: 13.5px;
  font-weight: 500;
  color: var(--ink);
  line-height: 1.4;
}

.schedule-activity-duration {
  font-size: 11.5px;
  color: var(--ink-soft);
  font-weight: 400;
  font-family: var(--font-mono, "JetBrains Mono", monospace);
}

.schedule-pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid var(--border);
}

.pagination-btn {
  background: none;
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 4px 10px;
  font-size: 12px;
  cursor: pointer;
  color: var(--ink);
  transition: all 0.2s ease;
}

.pagination-btn:hover:not(:disabled) {
  background: var(--surface);
  border-color: var(--primary);
}

.pagination-btn:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

.pagination-info {
  font-size: 12px;
  color: var(--muted);
  font-weight: 500;
}

.coach-card {
  background: linear-gradient(155deg, var(--primary-dark), var(--primary));
  color: #fff;
  border: none;
  position: relative;
  overflow: hidden;
}

.coach-card::after {
  content: "";
  position: absolute;
  right: -40px;
  top: -40px;
  width: 180px;
  height: 180px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1), transparent 70%);
}

.coach-eyebrow {
  font-size: 11.5px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: rgba(255, 255, 255, 0.75);
  font-weight: 600;
  margin-bottom: 10px;
}

.coach-msg {
  font-family: var(--font-display, "Plus Jakarta Sans", sans-serif);
  font-size: 19px;
  line-height: 1.45;
  max-width: 860px;
  width: 100%;
  font-weight: 500;
}
.coach-msg * {
  width: 100%;
}

.coach-actions {
  display: flex;
  gap: 10px;
  margin-top: 12px;
}

.btn {
  border: none;
  border-radius: 999px;
  padding: 9px 16px;
  font-size: 13.5px;
  font-weight: 600;
  cursor: pointer;
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
  transition: filter 0.15s ease;
}

.btn-light {
  background: rgba(255, 255, 255, 0.16);
  color: #fff;
}

.btn-light:hover {
  background: rgba(255, 255, 255, 0.24);
}

.btn-solid {
  background: var(--accent);
  color: var(--primary-dark);
}

.btn-solid:hover {
  filter: brightness(1.04);
}

.btn-outline {
  background: transparent;
  border: 1px solid var(--border);
  color: var(--ink-soft);
}

.btn-outline:hover {
  border-color: var(--primary);
  color: var(--primary-dark);
}

.task-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 4px;
  border-bottom: 1px solid var(--border);
}

.task-row:last-child {
  border-bottom: none;
}

.checkbox {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  border: 1.5px solid var(--muted);
  flex-shrink: 0;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
}
.checkbox:hover {
  border-color: var(--primary);
  background: rgba(79, 70, 229, 0.05);
}

.checkbox.done {
  background: var(--success) !important;
  border-color: var(--success) !important;
}

.checkbox.done::after {
  content: "✓";
  color: #fff;
  font-size: 11px;
  font-weight: bold;
}

.task-title {
  font-size: 14.5px;
  font-weight: 500;
}

.task-title.done {
  color: var(--muted);
  text-decoration: line-through;
}

.task-meta {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 8px;
}

.tag {
  font-size: 11px;
  font-weight: 600;
  padding: 3px 9px;
  border-radius: 999px;
}

.tag-health {
  background: #E9F2E4;
  color: #4A7A3A;
}

.tag-work {
  background: var(--primary-tint);
  color: var(--primary-dark);
}

.tag-home {
  background: var(--accent-tint);
  color: #9A6420;
}

.side-stack {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.streak-row {
  display: flex;
  align-items: center;
  gap: 14px;
}

.streak-days {
  display: flex;
  gap: 6px;
  margin-top: 12px;
}

.day-dot {
  width: 26px;
  height: 26px;
  border-radius: 8px;
  background: var(--surface-2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10.5px;
  font-family: var(--font-mono, "JetBrains Mono", monospace);
  color: var(--muted);
}

.day-dot.filled {
  background: var(--accent);
  color: #fff;
  font-weight: 600;
}

.quick-add {
  display: flex;
  align-items: center;
  gap: 10px;
  border: 1px solid var(--border);
  border-radius: 999px;
  padding: 11px 16px;
  margin-top: 12px;
  background: var(--surface);
}

.quick-add-trigger {
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  border: none;
  background: var(--surface);
  padding: 11px 16px;
  border-radius: 999px;
  cursor: pointer;
  transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
  font-size: 14px;
  color: var(--muted);
  border: 1px solid var(--border);
}

.quick-add-trigger:hover {
  border-color: var(--primary);
  color: var(--ink);
  box-shadow: 0 2px 8px rgba(13, 148, 136, 0.1);
}

.quick-add-trigger svg {
  color: var(--muted);
  transition: color 200ms cubic-bezier(0.4, 0, 0.2, 1);
}

.quick-add-trigger:hover svg {
  color: var(--primary);
}

.add-task-form {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg, 24px);
  margin-top: 12px;
  box-shadow: var(--shadow-lg);
  animation: slideDown 200ms cubic-bezier(0.4, 0, 0.2, 1);
  overflow: hidden;
  backdrop-filter: blur(16px);
}

[data-theme=dark] .add-task-form {
  background: rgba(20, 19, 34, 0.75);
  border: 1.5px solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 30px 60px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(255, 255, 255, 0.05) inset;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
.add-task-form-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 24px;
  border-bottom: 1.5px solid var(--border);
}

[data-theme=dark] .add-task-form-header {
  border-bottom-color: rgba(255, 255, 255, 0.08);
}

.add-task-form-header h3 {
  font-size: 18px;
  font-weight: 700;
  margin: 0;
  color: var(--ink);
  font-family: var(--font-display, "Plus Jakarta Sans", sans-serif);
}

.add-task-close {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-2);
  border: none;
  border-radius: 50%;
  cursor: pointer;
  transition: all 0.2s ease;
  color: var(--muted);
}

[data-theme=dark] .add-task-close {
  background: rgba(255, 255, 255, 0.05);
}

.add-task-close:hover {
  background: rgba(239, 68, 68, 0.08);
  color: #ef4444;
}

[data-theme=dark] .add-task-close:hover {
  background: rgba(239, 68, 68, 0.2);
}

.add-task-form-body {
  display: flex;
  flex-direction: column;
  gap: 16px;
  padding: 24px;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.form-group label {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--muted);
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
}

.form-input,
.form-select,
.form-textarea {
  width: 100%;
  padding: 12px 14px;
  border: 1.5px solid var(--border);
  border-radius: 12px;
  font-size: 14px;
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
  color: var(--ink);
  background: var(--surface-2);
  transition: all 0.2s ease;
  outline: none;
}

[data-theme=dark] .form-input,
[data-theme=dark] .form-select,
[data-theme=dark] .form-textarea {
  background: rgba(10, 9, 18, 0.35);
  border-color: rgba(255, 255, 255, 0.08);
}

.form-input:focus,
.form-select:focus,
.form-textarea:focus {
  border-color: var(--primary);
  background: var(--surface);
  box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.15);
}

[data-theme=dark] .form-input:focus,
[data-theme=dark] .form-select:focus,
[data-theme=dark] .form-textarea:focus {
  background: rgba(10, 9, 18, 0.6);
  border-color: var(--primary);
}

.form-input::placeholder,
.form-textarea::placeholder {
  color: var(--muted);
}

.form-textarea {
  resize: vertical;
  min-height: 80px;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.add-task-form-footer {
  display: flex;
  justify-content: flex-end;
  gap: 12px;
  padding: 20px 24px;
  background: var(--surface-2);
  border-top: 1px solid var(--border);
}

.add-task-form-footer .btn {
  min-width: 100px;
}

.add-task-form-footer .btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.color-picker-wrapper {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.color-input {
  width: 100%;
  height: 40px;
  border: 1px solid var(--border);
  border-radius: 8px;
  cursor: pointer;
  padding: 4px;
  background: var(--surface);
  transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
}

.color-input:hover {
  border-color: var(--primary);
}

.color-presets {
  display: grid;
  grid-template-columns: repeat(10, 1fr);
  gap: 6px;
}

.color-preset {
  width: 100%;
  aspect-ratio: 1;
  border: 2px solid var(--border);
  border-radius: 6px;
  cursor: pointer;
  transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  min-height: 24px;
}

.color-preset:hover {
  transform: scale(1.1);
  border-color: var(--primary);
}

.color-preset.active {
  border-color: var(--primary);
  box-shadow: 0 0 0 2px var(--surface), 0 0 0 4px var(--primary);
}

.add-task-form-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  padding: 20px;
  animation: fadeIn 200ms cubic-bezier(0.4, 0, 0.2, 1);
}

.modal-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(10, 9, 18, 0.5);
  backdrop-filter: blur(8px);
  z-index: 1;
}

.add-task-form-modal .add-task-form {
  position: relative;
  max-width: 500px;
  width: 100%;
  margin: 0;
  animation: slideUp 200ms cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 2;
  max-height: 90vh;
  display: flex;
  flex-direction: column;
}

.add-task-form-modal .add-task-form-header {
  flex-shrink: 0;
  padding: 20px 24px;
  border-bottom: 1px solid var(--border);
}

.add-task-form-modal .add-task-form-body {
  flex: 1;
  overflow-y: auto;
  padding: 24px;
}

.add-task-form-modal .add-task-form-footer {
  flex-shrink: 0;
  padding: 20px 24px;
  border-top: 1px solid var(--border);
}

@media (max-width: 768px) {
  .add-task-form-modal {
    padding: 10px;
  }
  .add-task-form-modal .add-task-form {
    max-height: 95vh;
  }
  .add-task-form-header,
  .add-task-form-body,
  .add-task-form-footer {
    padding: 12px;
  }
  .form-row {
    grid-template-columns: 1fr;
  }
  .color-presets {
    grid-template-columns: repeat(5, 1fr);
  }
}
@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
.section-title {
  font-size: 13.5px;
  font-weight: 700;
  margin-bottom: 14px;
  color: var(--ink-soft);
}

.bar-row {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-top: 12px;
}

.bar-label {
  width: 70px;
  font-size: 12.5px;
  color: var(--ink-soft);
  flex-shrink: 0;
}

.bar-track {
  flex: 1;
  height: 8px;
  background: var(--surface-2);
  border-radius: 99px;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  background: var(--primary);
  border-radius: 99px;
}

.board-cols {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  padding: 12px;
}

.board-cols.show-review {
  grid-template-columns: repeat(4, 1fr);
}

.board-cols > div {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.col-head {
  display: flex;
  align-items: center;
