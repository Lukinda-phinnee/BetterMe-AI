}

.add-task-form-footer .btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.color-picker-wrapper {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.color-input {
  width: 100%;
  height: 40px;
  border: 1px solid var(--border);
  border-radius: 8px;
  cursor: pointer;
  padding: 4px;
  background: var(--surface);
  transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
}

