@media (min-width: 769px) {
  .mobile-menu-btn {
    display: none;
  }
  .sidebar-overlay {
    display: none !important;
  }
}
.ai-fab {
  position: fixed;
  bottom: 32px;
  right: 32px;
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 14px 22px;
  background: linear-gradient(135deg, #4F46E5, #7C3AED);
  color: #fff;
  border: none;
  border-radius: 999px;
  font-size: 14px;
  font-weight: 700;
  cursor: pointer;
  box-shadow: 0 8px 28px rgba(79, 70, 229, 0.45), 0 0 0 1px rgba(255, 255, 255, 0.1) inset;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 100;
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
  letter-spacing: -0.01em;
}
.ai-fab::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.15), transparent);
  pointer-events: none;
}

.ai-fab:hover {
  transform: translateY(-3px) scale(1.02);
  box-shadow: 0 14px 40px rgba(79, 70, 229, 0.55), 0 0 0 1px rgba(255, 255, 255, 0.15) inset;
}

.ai-fab:active {
  transform: translateY(-1px) scale(0.99);
}

.ai-fab svg {
  width: 18px;
  height: 18px;
  stroke: #fff;
  stroke-width: 2;
  fill: none;
}

/* ── AI Chat Panel ──────────────────────────────────── */
.ai-chat-panel {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  width: 420px;
  background: var(--surface);
  border-left: 1.5px solid var(--border);
  box-shadow: -20px 0 60px rgba(0, 0, 0, 0.12);
  display: flex;
  flex-direction: column;
  z-index: 1000;
  animation: slideInRight 0.28s cubic-bezier(0.4, 0, 0.2, 1);
  overflow: hidden;
}

[data-theme=dark] .ai-chat-panel {
  background: #0E0D1B;
  border-left-color: rgba(255, 255, 255, 0.06);
  box-shadow: -20px 0 80px rgba(0, 0, 0, 0.6);
}

@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(100%);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}
.ai-chat-panel.closing {
  animation: slideOutRight 0.24s cubic-bezier(0.4, 0, 1, 1) forwards;
}

@keyframes slideOutRight {
  from {
    opacity: 1;
    transform: translateX(0);
  }
  to {
    opacity: 0;
    transform: translateX(100%);
  }
}
/* Header */
.ai-chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 20px;
  background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
}
.ai-chat-header::after {
  content: "";
  position: absolute;
  right: -40px;
  top: -40px;
  width: 160px;
  height: 160px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.12), transparent 70%);
  pointer-events: none;
}

.ai-chat-header-left {
  display: flex;
  align-items: center;
  gap: 12px;
  position: relative;
  z-index: 1;
}

.ai-chat-avatar {
  width: 40px;
  height: 40px;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1.5px solid rgba(255, 255, 255, 0.25);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  /* Subtle pulse on the avatar */
  animation: avatarPulse 3s ease-in-out infinite;
}

@keyframes avatarPulse {
  0%, 100% {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2), 0 0 0 0 rgba(255, 255, 255, 0.2);
  }
  50% {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2), 0 0 0 6px rgba(255, 255, 255, 0);
  }
}
.ai-chat-avatar svg {
  width: 20px;
  height: 20px;
  stroke: #fff;
  stroke-width: 2;
  fill: none;
}

.ai-chat-title {
  font-size: 15px;
  font-weight: 700;
  color: #fff;
  font-family: var(--font-display, "Plus Jakarta Sans", sans-serif);
  letter-spacing: -0.01em;
}

.ai-chat-subtitle {
  font-size: 11px;
  color: rgba(255, 255, 255, 0.72);
  margin-top: 2px;
  font-weight: 500;
}

.ai-chat-close {
  width: 32px;
  height: 32px;
  background: rgba(255, 255, 255, 0.12);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s ease;
  position: relative;
  z-index: 1;
}

.ai-chat-close:hover {
  background: rgba(255, 255, 255, 0.22);
  transform: scale(1.08);
}

.ai-chat-close svg {
  width: 14px;
  height: 14px;
  stroke: #fff;
  stroke-width: 2.5;
  fill: none;
}

/* Messages area */
.ai-chat-messages {
  flex: 1;
  overflow-y: auto;
  padding: 20px 16px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

/* Empty state */
.ai-chat-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 40px 20px;
  gap: 14px;
  height: 100%;
}

.ai-chat-empty-icon {
  width: 64px;
  height: 64px;
  background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 24px rgba(79, 70, 229, 0.35);
  margin-bottom: 4px;
  animation: iconFloat 3s ease-in-out infinite;
}

@keyframes iconFloat {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-6px);
  }
}
.ai-chat-empty-icon svg {
  width: 28px;
  height: 28px;
  stroke: #fff;
  stroke-width: 1.8;
  fill: none;
}

.ai-chat-empty-title {
  font-size: 18px;
  font-weight: 700;
  color: var(--ink);
  font-family: var(--font-display, "Plus Jakarta Sans", sans-serif);
  letter-spacing: -0.02em;
}

.ai-chat-empty-text {
  font-size: 13px;
  color: var(--muted);
  line-height: 1.6;
  max-width: 260px;
}

/* Suggestion chips */
.ai-chat-suggestions {
  display: flex;
  flex-direction: column;
  gap: 8px;
  width: 100%;
  margin-top: 4px;
}

.ai-chat-suggestion {
  padding: 11px 14px;
  background: var(--surface-2);
  border: 1.5px solid var(--border);
  border-radius: 12px;
  font-size: 13px;
  font-weight: 500;
  color: var(--ink-soft);
  text-align: left;
  cursor: pointer;
  transition: all 0.2s ease;
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
}

.ai-chat-suggestion:hover {
  background: var(--primary-tint);
  border-color: var(--primary);
  color: var(--primary);
  transform: translateX(3px);
}

/* Message bubbles */
.ai-chat-message {
  display: flex;
  gap: 10px;
  align-items: flex-end;
  max-width: 100%;
  animation: messageFadeIn 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

@keyframes messageFadeIn {
  from {
    opacity: 0;
    transform: translateY(6px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
.ai-chat-message.user {
  flex-direction: row;
  margin-left: auto;
}

.ai-chat-message-avatar {
  width: 30px;
  height: 30px;
  background: linear-gradient(135deg, #4F46E5, #7C3AED);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 2px 8px rgba(79, 70, 229, 0.3);
}

.ai-chat-message-avatar svg {
  width: 14px;
  height: 14px;
  stroke: #fff;
  stroke-width: 2;
  fill: none;
}

.ai-chat-message-content {
  padding: 12px 16px;
  border-radius: 18px;
  font-size: 13.5px;
  line-height: 1.55;
  max-width: min(560px, 78%);
  word-wrap: break-word;
  white-space: normal;
}

.ai-chat-message.assistant .ai-chat-message-content {
  background: transparent;
  color: var(--ink);
  border: none;
  padding: 0;
}

[data-theme=dark] .ai-chat-message.assistant .ai-chat-message-content {
  color: #ffffff;
}

.ai-chat-message.user .ai-chat-message-content {
  background: var(--surface);
  color: var(--ink);
  border: 1px solid var(--border);
  border-bottom-right-radius: 4px;
}

[data-theme=dark] .ai-chat-message.user .ai-chat-message-content {
  background: #ffffff;
  color: #000000;
  border-color: rgba(255, 255, 255, 0.1);
}

/* Typing indicator */
.ai-chat-typing {
  display: flex;
  gap: 5px;
  padding: 14px 18px;
  align-items: center;
}

.ai-chat-typing span {
  width: 7px;
  height: 7px;
  background: var(--primary);
  border-radius: 50%;
  animation: typingBounce 1.4s ease-in-out infinite;
  opacity: 0.7;
}

.ai-chat-typing span:nth-child(2) {
  animation-delay: 0.2s;
}

.ai-chat-typing span:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typingBounce {
  0%, 60%, 100% {
    transform: translateY(0);
    opacity: 0.5;
  }
  30% {
    transform: translateY(-6px);
    opacity: 1;
  }
}
/* Input area */
.ai-chat-input-wrapper {
  display: flex;
  align-items: flex-end;
  gap: 10px;
  padding: 16px;
  border-top: 1.5px solid var(--border);
  background: var(--surface);
  flex-shrink: 0;
}

[data-theme=dark] .ai-chat-input-wrapper {
  background: rgba(10, 9, 18, 0.6);
  border-top-color: rgba(255, 255, 255, 0.07);
}

.ai-chat-input {
  flex: 1;
  padding: 12px 16px;
  background: var(--surface-2);
  border: 1.5px solid var(--border);
  border-radius: 16px;
  font-size: 14px;
  color: var(--ink);
  resize: none;
  outline: none;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
  font-family: var(--font-body, "Plus Jakarta Sans", sans-serif);
  line-height: 1.5;
  min-height: 44px;
  max-height: 120px;
}

[data-theme=dark] .ai-chat-input {
  background: rgba(255, 255, 255, 0.04);
  border-color: rgba(255, 255, 255, 0.08);
}

.ai-chat-input:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.15);
  background: var(--surface);
}

.ai-chat-input::placeholder {
  color: var(--muted);
}

.ai-chat-send {
  width: 44px;
  height: 44px;
  background: linear-gradient(135deg, #4F46E5, #7C3AED);
  border: none;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s ease;
  flex-shrink: 0;
  box-shadow: 0 4px 14px rgba(79, 70, 229, 0.35);
}

.ai-chat-send:hover:not(:disabled) {
  transform: scale(1.08) translateY(-1px);
  box-shadow: 0 8px 20px rgba(79, 70, 229, 0.45);
}

.ai-chat-send:active:not(:disabled) {
  transform: scale(0.96);
}

.ai-chat-send:disabled {
  opacity: 0.4;
  cursor: not-allowed;
  box-shadow: none;
}

.ai-chat-send svg {
  width: 17px;
  height: 17px;
  stroke: #fff;
  stroke-width: 2;
  fill: none;
  margin-left: 2px; /* optical center for arrow */
}

/* Responsive */
@media (max-width: 768px) {
  .ai-chat-panel {
    width: 100%;
    border-left: none;
  }
  .ai-chat-message-content {
    max-width: calc(100% - 50px);
