{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@betterme/core": ["../../packages/core"],
      "@betterme/db": ["../../packages/db"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
